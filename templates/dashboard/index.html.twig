{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Admin Dashboard{% endblock %}

{% block main %}
<div class="dashboard-welcome">
    <div class="dashboard-welcome__icon">&#127919;</div>
    <h2 class="dashboard-welcome__title">Your dashboard is ready</h2>
    <p class="dashboard-welcome__text">
        This is a blank dashboard. Customize it by editing<br>
        <code>templates/dashboard/index.html.twig</code>
    </p>
    <p class="dashboard-welcome__text">
        Add widgets, charts, stats, or any content you need.<br>
        The sidebar menu is configured in<br>
        <code>src/Infrastructure/Http/Controller/DashboardController.php</code>
    </p>
</div>
{% endblock %}
