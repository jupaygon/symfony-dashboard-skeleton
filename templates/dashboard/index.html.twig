{% extends '@EasyAdmin/page/content.html.twig' %}

{% block content_title %}Dashboard{% endblock %}

{% block main %}
<div style="max-width: 700px; margin: 60px auto; text-align: center; color: #64748b;">
    <div style="font-size: 3rem; margin-bottom: 16px;">&#127919;</div>
    <h2 style="font-size: 1.5rem; font-weight: 600; color: #334155; margin-bottom: 12px;">Your dashboard is ready</h2>
    <p style="font-size: 1rem; line-height: 1.7; margin-bottom: 24px;">
        This is a blank dashboard. Customize it by editing<br>
        <code style="background: #f1f5f9; padding: 3px 8px; border-radius: 4px; font-size: 0.9rem;">templates/dashboard/index.html.twig</code>
    </p>
    <p style="font-size: 0.92rem; line-height: 1.7;">
        Add widgets, charts, stats, or any content you need.<br>
        The sidebar menu is configured in<br>
        <code style="background: #f1f5f9; padding: 3px 8px; border-radius: 4px; font-size: 0.9rem;">src/Infrastructure/Http/Controller/DashboardController.php</code>
    </p>
</div>
{% endblock %}
