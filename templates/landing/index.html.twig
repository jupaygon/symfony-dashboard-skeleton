<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Skeleton</title>
    <link rel="stylesheet" href="{{ asset('brands/' ~ brand ~ '/css/skin.css') }}">
    <link rel="stylesheet" href="{{ asset('css/public.css') }}">
    <link rel="icon" href="/resources/brands/{{ brand }}/images/logo.svg">
</head>
<body class="landing">
    <div class="landing__container">
        <header class="landing__header">
            <div class="landing__logo"></div>
            <h1 class="landing__title">Dashboard Skeleton</h1>
            <p class="landing__subtitle">Admin panel powered by Symfony 8 + EasyAdmin 5</p>
        </header>

        <section class="landing__features">
            <div class="landing__feature">
                <div class="landing__feature-icon">
                    <img src="/resources/brands/{{ brand }}/images/icons/multi-tenant.svg" alt="Multi-tenant">
                </div>
                <h3 class="landing__feature-title">Multi-tenant</h3>
                <p class="landing__feature-text">Organizations, roles, and user management with admin isolation per organization.</p>
            </div>
            <div class="landing__feature">
                <div class="landing__feature-icon">
                    <img src="/resources/brands/{{ brand }}/images/icons/hexagonal.svg" alt="Hexagonal Architecture">
                </div>
                <h3 class="landing__feature-title">Hexagonal Architecture</h3>
                <p class="landing__feature-text">Clean separation: Domain, Application, Infrastructure. Ready to scale.</p>
            </div>
            <div class="landing__feature">
                <div class="landing__feature-icon">
                    <img src="/resources/brands/{{ brand }}/images/icons/branding.svg" alt="Brand Skinning">
                </div>
                <h3 class="landing__feature-title">Brand Skinning</h3>
                <p class="landing__feature-text">Host-based branding with CSS variables. Switch themes per domain.</p>
            </div>
        </section>

        <div class="landing__cta">
            <a href="{{ path('app_login') }}" class="landing__btn">Sign in</a>
        </div>
    </div>
</body>
</html>
