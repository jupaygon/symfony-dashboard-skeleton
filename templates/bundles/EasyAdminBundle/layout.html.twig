{% extends '@!EasyAdmin/layout.html.twig' %}

{% set brand = current_brand() %}

{% block head_favicon %}
    <link rel="icon" type="image/svg+xml" href="{{ asset('brands/' ~ brand.key ~ '/images/favicon/favicon.svg') }}">
{% endblock head_favicon %}

{% block wrapper_wrapper %}
    {% if current_brand().isTopnav() %}
        {# ── Top Navigation Bar ── #}
        <nav class="topnav-bar">
            <div class="topnav-bar__logo"></div>

            <div class="topnav-bar__items">
                {% for menuItem in ea().mainMenu.items %}
                    {% if not menuItem.isMenuSection %}
                        {% set is_submenu_item_with_no_items = menuItem.type == constant('EasyCorp\\Bundle\\EasyAdminBundle\\Dto\\MenuItemDto::TYPE_SUBMENU') and not menuItem.hasSubItems %}
                        {% if not is_submenu_item_with_no_items %}
                            {% if menuItem.hasSubItems %}
                                {% set has_selected_child = false %}
                                {% for subItem in menuItem.subItems %}
                                    {% if subItem.isSelected %}{% set has_selected_child = true %}{% endif %}
                                {% endfor %}
                                <div class="topnav-bar__item {{ (menuItem.isSelected or has_selected_child) ? 'active' }}" data-topnav-dropdown>
                                    <button class="topnav-bar__link {{ (menuItem.isSelected or has_selected_child) ? 'active' }}" type="button">
                                        {% if menuItem.icon is not empty %}<i class="{{ menuItem.icon }} icon"></i>{% endif %}
                                        <span>{{ menuItem.label|trans }}</span>
                                        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="10" height="10"><path d="M6 9l6 6 6-6"/></svg>
                                    </button>
                                    <div class="topnav-bar__dropdown">
                                        {% for subItem in menuItem.subItems %}
                                            {% if not subItem.isMenuSection %}
                                                <a href="{{ subItem.linkUrl }}" class="topnav-bar__dropdown-item {{ subItem.isSelected ? 'active' }}">
                                                    {% if subItem.icon is not empty %}<i class="{{ subItem.icon }}"></i>{% endif %}
                                                    <span>{{ subItem.label|trans }}</span>
                                                </a>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </div>
                            {% else %}
                                <div class="topnav-bar__item {{ menuItem.isSelected ? 'active' }}">
                                    <a class="topnav-bar__link {{ menuItem.isSelected ? 'active' }}" href="{{ menuItem.linkUrl }}">
                                        {% if menuItem.icon is not empty %}<i class="{{ menuItem.icon }} icon"></i>{% endif %}
                                        <span>{{ menuItem.label|trans }}</span>
                                    </a>
                                </div>
                            {% endif %}
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>

            <div class="topnav-bar__spacer"></div>

            {# ── Right side: user + settings ── #}
            <div class="topnav-bar__right">
                {% if ea.user is not null %}
                    <i class="fa-solid fa-user topnav-bar__user-icon"></i>
                    <span class="topnav-bar__user">{{ ea.userMenu.name }}</span>
                {% endif %}
                {% include 'bundles/EasyAdminBundle/includes/_settings_dropdown.html.twig' %}
            </div>
        </nav>
    {% endif %}

    {{ parent() }}
{% endblock %}

{% block body_javascript %}
    {{ parent() }}

    {% if current_brand().isTopnav() %}
    <script>
    document.querySelectorAll('[data-topnav-dropdown]').forEach(function(item) {
        var btn = item.querySelector('.topnav-bar__link');
        if (btn) {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                document.querySelectorAll('[data-topnav-dropdown].open').forEach(function(other) {
                    if (other !== item) other.classList.remove('open');
                });
                item.classList.toggle('open');
            });
        }
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('[data-topnav-dropdown].open').forEach(function(item) {
            item.classList.remove('open');
        });
    });
    </script>
    {% endif %}
{% endblock %}

{% block search_wrapper %}
    {% if current_brand().isTopnav() %}
        {# Empty — search is moved below the title via content_header_wrapper #}
    {% else %}
        {{ parent() }}
    {% endif %}
{% endblock %}

{% block content_header_wrapper %}
    {{ parent() }}

    {% if current_brand().isTopnav() %}
        {% set has_search = ea.crud is not null and ea.crud.isSearchEnabled %}
        {% if has_search %}
            <div class="topnav-search-bar">
                {% set formActionUrl = null %}
                {% if ea.usePrettyUrls %}
                    {% set crudController = ea.request.attributes.get('crudControllerFqcn') ?? ea.request.query.get('crudControllerFqcn') %}
                    {% set formActionUrl = ea_url().setController(crudController).setAction('index').set('page', 1) %}
                {% endif %}
                <form class="form-action-search" method="get" {% if formActionUrl %}action="{{ formActionUrl }}"{% endif %}>
                    {% if not ea.usePrettyUrls %}
                        <input type="hidden" name="crudAction" value="index">
                        <input type="hidden" name="crudControllerFqcn" value="{{ ea.request.query.get('crudControllerFqcn') }}">
                        <input type="hidden" name="page" value="1">
                    {% endif %}
                    <div class="form-group">
                        <div class="form-widget">
                            <twig:ea:Icon name="internal:search" class="content-search-icon" />
                            <label class="content-search-label" data-value="{{ app.request.query.get('query') }}">
                                <input class="form-control {{ app.request.query.get('query') is null ? 'is-blank' }}" type="search" name="query" value="{{ app.request.query.get('query') ?? '' }}" placeholder="{{ t('action.search', ea.i18n.translationParameters, 'EasyAdminBundle')|trans }}" spellcheck="false" autocorrect="off" onInput="this.parentNode.dataset.value=this.value">
                            </label>
                            {% if app.request.query.get('query') %}
                                {% set search_reset_url = ea_url().unset('query') %}
                                <a href="{{ search_reset_url }}" class="content-search-reset">
                                    <twig:ea:Icon name="internal:xmark" />
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </form>
            </div>
        {% endif %}
    {% endif %}
{% endblock %}

{% block settings_dropdown_wrapper %}
    {% include 'bundles/EasyAdminBundle/includes/_settings_dropdown.html.twig' %}

    <script>
    document.querySelectorAll('.sidebar-pref-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            fetch('/api/user/preference/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ field: 'sidebar_collapsed' })
            }).then(function() { window.location.reload(); });
        });
    });

    document.querySelectorAll('.content-width-pref-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            fetch('/api/user/preference/toggle', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ field: 'content_maximized' })
            }).then(function() { window.location.reload(); });
        });
    });

    document.querySelectorAll('.brand-pref-item').forEach(function(item) {
        item.addEventListener('click', function(e) {
            e.preventDefault();
            e.stopPropagation();
            var brand = this.getAttribute('data-brand');
            fetch('/api/user/preference/set', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ field: 'brand_override', value: brand })
            }).then(function() { window.location.reload(); });
        });
    });

    </script>
{% endblock %}
